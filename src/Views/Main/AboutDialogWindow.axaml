<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:main="using:perinma.Views.Main"
        x:DataType="main:AboutDialogViewModel"
        mc:Ignorable="d" d:DesignWidth="600" d:DesignHeight="500"
        x:Class="perinma.Views.Main.AboutDialogWindow"
        Title="About"
        Width="600"
        Height="500"
        CanResize="False"
        WindowStartupLocation="CenterOwner">

    <DockPanel>
        <Border DockPanel.Dock="Top" Background="{DynamicResource SystemChromeMediumColor}" Padding="20">
            <StackPanel Spacing="5">
                <TextBlock Text="{Binding AppName}" FontSize="24" FontWeight="Bold" />
                <TextBlock Text="{Binding Description}" FontSize="14" Foreground="Gray" />
                <TextBlock Text="{Binding Version}" FontSize="12" Foreground="Gray" />
                <TextBlock Text="{Binding FullVersion}" FontSize="10" Foreground="{DynamicResource SystemBaseMediumLowColor}" />
            </StackPanel>
        </Border>

        <ScrollViewer DockPanel.Dock="Top" VerticalScrollBarVisibility="Auto" Padding="20">
            <TextBlock Text="{Binding LicenseText}"
                       TextWrapping="Wrap"
                       FontFamily="Consolas,Courier New,monospace"
                       FontSize="11"
                       Foreground="{DynamicResource SystemBaseHighColor}" />
        </ScrollViewer>

        <Border DockPanel.Dock="Bottom" 
                Background="{DynamicResource SystemChromeMediumLowColor}"
                Padding="20"
                BorderBrush="{DynamicResource SystemChromeLowColor}"
                BorderThickness="0,1,0,0">
            <Button Content="Close"
                    Command="{Binding CloseCommand}"
                    HorizontalAlignment="Right"
                    MinWidth="100" />
        </Border>
    </DockPanel>

</Window>
