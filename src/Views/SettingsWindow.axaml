<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
        x:Class="perinma.Views.SettingsWindow"
        Title="Settings">
    <DockPanel>
        <TreeView DockPanel.Dock="Left" SelectionMode="AlwaysSelected">
            <TreeViewItem Header="General" IsSelected="True">asd</TreeViewItem>
            <TreeViewItem Header="Accounts">asd 2</TreeViewItem>
        </TreeView>
    </DockPanel>
    
</Window>
