<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:wizard="using:perinma.Views.Settings.AddAccountWizard"
             x:DataType="wizard:GoogleConnectionStepViewModel"
             mc:Ignorable="d" d:DesignWidth="600" d:DesignHeight="400"
             x:Class="perinma.Views.Settings.AddAccountWizard.GoogleConnectionStepView">

    <StackPanel Margin="20" Spacing="15">
        <TextBlock Text="Google Authentication" FontSize="18" FontWeight="SemiBold" />

        <TextBlock Text="{Binding StatusMessage}"
                   TextWrapping="Wrap"
                   MinHeight="60" />

        <Button Content="Connect to Google"
                Command="{Binding ConnectCommand}"
                IsEnabled="{Binding !IsConnecting}"
                HorizontalAlignment="Left" />

        <ProgressBar IsIndeterminate="True"
                     IsVisible="{Binding IsConnecting}"
                     Height="4" />
    </StackPanel>

</UserControl>
