<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:settings="using:perinma.Views.Settings"
             x:DataType="settings:AccountListViewModel"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="perinma.Views.Settings.AccountListView">

    <StackPanel Margin="20">
        <DockPanel Margin="0,0,0,20">
            <TextBlock Text="Accounts" FontSize="24" FontWeight="Bold" DockPanel.Dock="Left" />
            <Button Content="Add Account"
                    Command="{Binding AddAccountCommand}"
                    HorizontalAlignment="Right"
                    DockPanel.Dock="Right" />
        </DockPanel>

        <ItemsControl ItemsSource="{Binding Accounts}">
            <ItemsControl.ItemTemplate>
                <DataTemplate x:DataType="settings:AccountViewModel">
                    <Border BorderBrush="Gray" BorderThickness="1" CornerRadius="5" Padding="10" Margin="0,0,0,10">
                        <DockPanel>
                            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" Spacing="5">
                                <Button Content="Reauthenticate"
                                        Command="{Binding $parent[UserControl].((settings:AccountListViewModel)DataContext).ReauthenticateAccountCommand}"
                                        CommandParameter="{Binding Id}"
                                        VerticalAlignment="Center"
                                        IsEnabled="{Binding $parent[UserControl].((settings:AccountListViewModel)DataContext).CanReauthenticate, FallbackValue=True}" />
                                <Button Content="Delete"
                                        Command="{Binding $parent[UserControl].((settings:AccountListViewModel)DataContext).DeleteAccountCommand}"
                                        CommandParameter="{Binding Id}"
                                        VerticalAlignment="Center" />
                            </StackPanel>
                            <StackPanel>
                                <TextBlock Text="{Binding Name}" FontSize="16" FontWeight="SemiBold" />
                                <TextBlock Text="{Binding Type}" FontSize="12" Foreground="Gray" />
                            </StackPanel>
                        </DockPanel>
                    </Border>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>

        <!-- Placeholder message when no accounts exist -->
        <TextBlock Text="No accounts configured"
                   Foreground="Gray"
                   IsVisible="{Binding !Accounts.Count}" />
    </StackPanel>

</UserControl>
