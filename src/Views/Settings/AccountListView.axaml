<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:settings="using:perinma.Views.Settings"
             x:DataType="settings:AccountListViewModel"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="perinma.Views.Settings.AccountListView">

    <StackPanel Margin="20">
        <TextBlock Text="Accounts" FontSize="24" FontWeight="Bold" Margin="0,0,0,20" />

        <ItemsControl ItemsSource="{Binding Accounts}">
            <ItemsControl.ItemTemplate>
                <DataTemplate x:DataType="settings:AccountViewModel">
                    <Border BorderBrush="Gray" BorderThickness="1" CornerRadius="5" Padding="10" Margin="0,0,0,10">
                        <StackPanel>
                            <TextBlock Text="{Binding Name}" FontSize="16" FontWeight="SemiBold" />
                            <TextBlock Text="{Binding Type}" FontSize="12" Foreground="Gray" />
                        </StackPanel>
                    </Border>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>

        <!-- Placeholder message when no accounts exist -->
        <TextBlock Text="No accounts configured"
                   Foreground="Gray"
                   IsVisible="{Binding !Accounts.Count}" />
    </StackPanel>

</UserControl>
