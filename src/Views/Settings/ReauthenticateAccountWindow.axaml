<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:settings="using:perinma.Views.Settings"
        x:DataType="settings:ReauthenticateAccountViewModel"
        mc:Ignorable="d" d:DesignWidth="600" d:DesignHeight="400"
        x:Class="perinma.Views.Settings.ReauthenticateAccountWindow"
        Title="Reauthenticate Account"
        Width="600"
        Height="400"
        CanResize="False">

    <DockPanel>
        <!-- Header -->
        <Border DockPanel.Dock="Top" Background="{DynamicResource SystemChromeMediumColor}" Padding="20">
            <StackPanel Spacing="10">
                <TextBlock Text="Reauthenticate Account" FontSize="20" FontWeight="Bold" />
                <TextBlock Text="{Binding AccountName}" FontSize="14" Foreground="Gray" />
            </StackPanel>
        </Border>

        <!-- Content area -->
        <ContentControl DockPanel.Dock="Top" HorizontalAlignment="Center" VerticalAlignment="Center">
            <StackPanel Spacing="20" MaxWidth="500">
                <TextBlock TextWrapping="Wrap" TextAlignment="Center">
                    <Run Text="You need to reauthenticate your Google account." />
                    <LineBreak />
                    <Run Text="This may be necessary if your access token expired or if you need to adjust permissions." />
                </TextBlock>

                <TextBlock Text="{Binding StatusMessage}"
                           TextWrapping="Wrap"
                           TextAlignment="Center"
                           Foreground="Gray"
                           MinHeight="80" />

                <Button Content="Reauthenticate"
                        Command="{Binding ReauthenticateCommand}"
                        IsEnabled="{Binding !IsConnecting}"
                        HorizontalAlignment="Center"
                        MinWidth="150" />

                <Button Content="Cancel"
                        Command="{Binding CancelCommand}"
                        IsEnabled="{Binding !IsConnecting}"
                        HorizontalAlignment="Center"
                        MinWidth="150" />
            </StackPanel>
        </ContentControl>
    </DockPanel>

</Window>
