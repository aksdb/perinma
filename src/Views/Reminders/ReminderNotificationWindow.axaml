<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:reminders="clr-namespace:perinma.Views.Reminders"
        x:DataType="reminders:ReminderListViewModel"
        mc:Ignorable="d" d:DesignWidth="500" d:DesignHeight="600"
        x:Class="perinma.Views.Reminders.ReminderNotificationWindow"
        Title="Reminders" Width="500" Height="600"
        CanResize="False" WindowStartupLocation="CenterOwner"
        Icon="/Assets/icon.ico">

    <Design.DataContext>
        <reminders:ReminderListViewModel />
    </Design.DataContext>

    <Window.Styles>
        <Style Selector="Button:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource AccentColor2}" />
        </Style>
        <Style Selector="Button:pointerover">
            <Setter Property="Cursor" Value="Hand" />
        </Style>
    </Window.Styles>

    <Grid RowDefinitions="Auto,*">
        <Border Grid.Row="0" Background="{DynamicResource AccentColor3}"
                Padding="20,15">
            <Grid ColumnDefinitions="*,Auto">
                <TextBlock Grid.Column="0"
                           Text="{Binding Reminders.Count, StringFormat='Reminders ({0})'}"
                           FontSize="18"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource AccentForeground2}"/>

                <Button Grid.Column="1"
                        Content="Dismiss All"
                        Command="{Binding DismissAllCommand}"
                        Padding="15,8"
                        Margin="10,0,0,0"
                        IsEnabled="{Binding Reminders.Count, Mode=OneWay}"/>
            </Grid>
        </Border>

        <ScrollViewer Grid.Row="1">
            <ItemsControl ItemsSource="{Binding Reminders}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="reminders:ReminderViewModel">
                        <Border Background="{DynamicResource SystemAltMediumHighBrush}"
                                Margin="15,10"
                                Padding="0"
                                CornerRadius="5"
                                BorderBrush="{DynamicResource SystemChromeMediumColor}"
                                BorderThickness="1">
                            <reminders:ReminderItemControl/>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </Grid>
</Window>
