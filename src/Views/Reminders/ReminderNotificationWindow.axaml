<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:reminders="clr-namespace:perinma.Views.Reminders"
        x:DataType="reminders:ReminderListViewModel"
        mc:Ignorable="d" d:DesignWidth="400" d:DesignHeight="450"
        x:Class="perinma.Views.Reminders.ReminderNotificationWindow"
        Title="Reminders" Width="450" MaxHeight="600" MinHeight="200" SizeToContent="Height"
        CanResize="False" WindowStartupLocation="CenterOwner"
        Icon="/Assets/avalonia-logo.ico">

    <Window.Styles>
        <Style Selector="Button.DismissAllButton">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="White"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="14,6"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>
        <Style Selector="Button.DismissAllButton:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#40FFFFFF"/>
        </Style>
        <Style Selector="Button:pointerover">
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
    </Window.Styles>

    <Grid RowDefinitions="Auto,*">
        <!-- Header -->
        <Border Grid.Row="0"
                Background="{DynamicResource AccentColor3}"
                Padding="16,12"
                CornerRadius="8,8,0,0">
            <Grid ColumnDefinitions="*,Auto">
                <StackPanel Grid.Column="0" Spacing="2">
                    <TextBlock Text="Upcoming Reminders"
                               FontSize="16"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource AccentForeground2}"/>

                    <TextBlock Text="{Binding Reminders.Count, StringFormat='{}{0} event(s)'}"
                               FontSize="12"
                               Opacity="0.85"
                               Foreground="{DynamicResource AccentForeground2}"/>
                </StackPanel>

                <Button Grid.Column="1"
                        Content="Dismiss All"
                        Classes="DismissAllButton"
                        Command="{Binding DismissAllCommand}"
                        IsEnabled="{Binding Reminders.Count, Mode=OneWay}"/>
            </Grid>
        </Border>

        <!-- Reminder List -->
        <ScrollViewer Grid.Row="1"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
            <ItemsControl ItemsSource="{Binding Reminders}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <StackPanel Spacing="8"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="reminders:ReminderViewModel">
                        <reminders:ReminderItemControl/>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </Grid>
</Window>
