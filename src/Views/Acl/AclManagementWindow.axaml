<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:acl="using:perinma.Views.Acl"
        x:DataType="acl:AclManagementViewModel"
        mc:Ignorable="d" d:DesignWidth="700" d:DesignHeight="600"
        x:Class="perinma.Views.Acl.AclManagementWindow"
        Title="Manage Permissions"
        Width="700"
        MaxWidth="900"
        MinWidth="600"
        MaxHeight="800"
        SizeToContent="WidthAndHeight"
        CanResize="False"
        WindowStartupLocation="CenterOwner">

    <Design.DataContext>
        <acl:AclManagementViewModel />
    </Design.DataContext>

    <Window.Resources>
        <acl:BooleanToColorConverter x:Key="BooleanToColorConverter" />
        <acl:SelectedBorderColorConverter x:Key="SelectedBorderColorConverter" />
    </Window.Resources>

    <StackPanel Margin="20">
        <!-- Calendar Info Header -->
        <StackPanel Spacing="12" Margin="0,0,0,20">
            <StackPanel Orientation="Horizontal" Spacing="12">
                <!-- Color indicator -->
                <Border Width="24"
                        Height="24"
                        CornerRadius="5"
                        Background="{Binding CalendarColor}"
                        VerticalAlignment="Center" />

                <!-- Calendar name -->
                <TextBlock Text="{Binding CalendarName}"
                           FontSize="18"
                           FontWeight="Bold"
                           VerticalAlignment="Center" />
            </StackPanel>

            <!-- Owner info -->
            <TextBlock Text="{Binding OwnerText}"
                       FontSize="12"
                       Foreground="Gray"
                       Margin="36,0,0,0"
                       TextWrapping="Wrap" />
        </StackPanel>

        <!-- Current User Privileges Banner -->
        <Border BorderBrush="Gray"
                BorderThickness="1"
                CornerRadius="5"
                Padding="16,12"
                Margin="0,0,0,20"
                IsVisible="{Binding ShowCurrentUserPrivileges}">
            <StackPanel Spacing="8">
                <TextBlock Text="Your Access:"
                           FontWeight="SemiBold"
                           FontSize="14" />

                <StackPanel Orientation="Horizontal" Spacing="12">
                    <!-- Read-only -->
                    <TextBlock Text="Read"
                               FontSize="12"
                               IsVisible="{Binding CanRead}" />

                    <!-- Read-write -->
                    <TextBlock Text="Write"
                               FontSize="12"
                               IsVisible="{Binding CanWrite}" />

                    <!-- Write-ACL -->
                    <TextBlock Text="Manage Permissions"
                               FontSize="12"
                               IsVisible="{Binding CanWriteAcl}" />

                    <!-- No access message -->
                    <TextBlock Text="View Only (cannot edit permissions)"
                               FontSize="12"
                               Foreground="Gray"
                               IsVisible="{Binding NotHasWriteAcl}" />
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Toolbar for Add/Remove actions -->
        <StackPanel Orientation="Horizontal"
                    Spacing="10"
                    HorizontalAlignment="Right"
                    Margin="0,0,0,10"
                    IsVisible="{Binding CanWriteAcl}">
            <Button Content="Add Permission"
                    Command="{Binding AddAceCommand}"
                    Padding="16,6"
                    IsEnabled="{Binding IsLoading, Converter={x:Static BoolConverters.Not}}" />
            <Button Content="Remove Selected"
                    Command="{Binding RemoveSelectedAceCommand}"
                    Padding="16,6"
                    IsEnabled="{Binding IsLoading, Converter={x:Static BoolConverters.Not}}" />
        </StackPanel>

        <!-- Main ACL List -->
        <ScrollViewer VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled"
                      MaxHeight="400">
            <ItemsControl ItemsSource="{Binding Aces}"
                          IsEnabled="{Binding IsLoading, Converter={x:Static BoolConverters.Not}}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="acl:AceItemViewModel">
                        <Border Background="Transparent"
                                Margin="0,0,0,6"
                                Padding="12,8"
                                CornerRadius="5"
                                BorderThickness="1"
                                BorderBrush="{Binding IsSelected, Converter={x:Static acl:SelectedBorderColorConverter.Instance}}"
                                PointerPressed="OnAceBorderPointerPressed"
                                Tag="{Binding}">

                            <DockPanel>
                                <!-- Action buttons (right-aligned) -->
                                <StackPanel DockPanel.Dock="Right"
                                            Orientation="Horizontal"
                                            Spacing="4"
                                            VerticalAlignment="Center"
                                            IsVisible="{Binding IsInherited, Converter={x:Static BoolConverters.Not}}">

                                    <!-- Edit button -->
                                    <Button Width="24"
                                            Height="24"
                                            Padding="0"
                                            Background="Transparent"
                                            BorderThickness="0"
                                            ToolTip.Tip="Edit"
                                            Command="{Binding EditCommand}"
                                            IsEnabled="{Binding IsProtected, Converter={x:Static BoolConverters.Not}}">
                                        <TextBlock Text="&gt;"
                                                   FontSize="12"
                                                   Foreground="{DynamicResource SystemControlForegroundBaseHighBrush}"
                                                   VerticalAlignment="Center"
                                                   HorizontalAlignment="Center" />
                                    </Button>

                                    <!-- Delete button -->
                                    <Button Width="24"
                                            Height="24"
                                            Padding="0"
                                            Background="Transparent"
                                            BorderThickness="0"
                                            ToolTip.Tip="Remove"
                                            Command="{Binding DeleteCommand}"
                                            IsEnabled="{Binding IsProtected, Converter={x:Static BoolConverters.Not}}">
                                        <TextBlock Text="&#215;"
                                                   FontSize="14"
                                                   Foreground="#D13438"
                                                   VerticalAlignment="Center"
                                                   HorizontalAlignment="Center" />
                                    </Button>
                                </StackPanel>

                                <!-- Grant/Deny indicator -->
                                <Border DockPanel.Dock="Right"
                                        CornerRadius="4"
                                        Padding="8,3"
                                        Margin="8,0"
                                        VerticalAlignment="Center">
                                    <Border.Background>
                                        <SolidColorBrush Color="{Binding IsGrant, Converter={StaticResource BooleanToColorConverter}}" />
                                    </Border.Background>
                                    <TextBlock Text="{Binding GrantDenyText}"
                                               FontSize="11"
                                               Foreground="White"
                                               FontWeight="SemiBold" />
                                </Border>

                                <!-- Principal info -->
                                <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                    <!-- Principal icon/type -->
                                    <Border Width="20"
                                            Height="20"
                                            CornerRadius="3"
                                            Background="{Binding PrincipalTypeColor}">
                                        <TextBlock Text="{Binding PrincipalTypeIcon}"
                                                   FontSize="10"
                                                   Foreground="White"
                                                   VerticalAlignment="Center"
                                                   HorizontalAlignment="Center" />
                                    </Border>

                                    <!-- Principal name/URL -->
                                    <TextBlock Text="{Binding PrincipalDisplayText}"
                                               FontWeight="SemiBold"
                                               VerticalAlignment="Center"
                                               TextTrimming="CharacterEllipsis"
                                               MaxWidth="300" />

                                    <!-- Inherited label -->
                                    <TextBlock Text="(Inherited)"
                                               FontSize="11"
                                               Foreground="Gray"
                                               VerticalAlignment="Center"
                                               IsVisible="{Binding IsInherited}" />

                                    <!-- Protected label -->
                                    <TextBlock Text="(Protected)"
                                               FontSize="11"
                                               Foreground="Gray"
                                               VerticalAlignment="Center"
                                               IsVisible="{Binding IsProtected}" />
                                </StackPanel>
                            </DockPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <!-- Loading indicator -->
        <Border IsVisible="{Binding IsLoading}">
            <StackPanel HorizontalAlignment="Center" Spacing="8">
                <ProgressBar Width="200"
                             Height="4"
                             IsIndeterminate="True" />
                <TextBlock Text="Loading permissions..."
                           FontSize="12"
                           Foreground="Gray"
                           HorizontalAlignment="Center" />
            </StackPanel>
        </Border>

        <!-- Save/Cancel buttons -->
        <StackPanel Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Spacing="10"
                    Margin="0,20,0,0">
            <Button Content="Cancel"
                    Command="{Binding CancelCommand}"
                    Width="100"
                    Padding="0,8"
                    IsEnabled="{Binding IsLoading, Converter={x:Static BoolConverters.Not}}" />
            <Button Content="Save Changes"
                    Command="{Binding SaveCommand}"
                    Width="120"
                    Padding="0,8"
                    IsEnabled="{Binding HasChanges}"
                    Classes="Accent" />
        </StackPanel>
    </StackPanel>

</Window>
