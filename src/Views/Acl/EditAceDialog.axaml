<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:acl="using:perinma.Views.Acl"
        x:DataType="acl:EditAceDialogViewModel"
        mc:Ignorable="d" d:DesignWidth="500" d:DesignHeight="450"
        x:Class="perinma.Views.Acl.EditAceDialog"
        Title="Edit Permission"
        Width="500"
        MaxWidth="600"
        MaxHeight="700"
        CanResize="False"
        SizeToContent="WidthAndHeight"
        WindowStartupLocation="CenterOwner">

    <StackPanel Margin="20">
        <!-- Principal Info (Read-only) -->
        <StackPanel Spacing="8">
            <TextBlock Text="Who has access?" FontWeight="SemiBold" FontSize="16" />

            <Border BorderBrush="Gray"
                    BorderThickness="1"
                    CornerRadius="5"
                    Padding="16"
                    Opacity="0.9">
                <StackPanel Orientation="Horizontal" Spacing="12">
                    <Border Width="24"
                            Height="24"
                            CornerRadius="5"
                            Background="{Binding PrincipalTypeColor}"
                            VerticalAlignment="Center">
                        <TextBlock Text="{Binding PrincipalTypeIcon}"
                                   FontSize="12"
                                   Foreground="White"
                                   VerticalAlignment="Center"
                                   HorizontalAlignment="Center" />
                    </Border>
                    <TextBlock Text="{Binding PrincipalDisplayText}"
                               FontWeight="SemiBold"
                               VerticalAlignment="Center" />
                </StackPanel>
            </Border>
        </StackPanel>

        <!-- Privilege Selection -->
        <StackPanel Spacing="12" Margin="0,20,0,0">
            <TextBlock Text="What permissions?" FontWeight="SemiBold" FontSize="16" />

            <!-- Preset Buttons -->
            <StackPanel Orientation="Horizontal" Spacing="10">
                <Button Content="Read Only"
                        Command="{Binding SetPresetCommand}"
                        CommandParameter="Read"
                        Padding="12,6" />
                <Button Content="Read/Write"
                        Command="{Binding SetPresetCommand}"
                        CommandParameter="ReadWrite"
                        Padding="12,6" />
                <Button Content="Full Access"
                        Command="{Binding SetPresetCommand}"
                        CommandParameter="Full"
                        Padding="12,6" />
            </StackPanel>
        </StackPanel>

        <!-- Custom Privileges -->
        <StackPanel Spacing="8" Margin="0,12,0,0">
            <TextBlock Text="Custom privileges:" FontSize="12" FontWeight="SemiBold" />

            <!-- Read Privileges -->
            <StackPanel Spacing="4">
                <CheckBox Content="Read" IsChecked="{Binding CanRead}" />
                <CheckBox Content="Read ACL" IsChecked="{Binding CanReadAcl}" />
            </StackPanel>

            <!-- Write Privileges -->
            <StackPanel Spacing="4" Margin="0,8,0,0">
                <CheckBox Content="Write" IsChecked="{Binding CanWrite}" />
                <CheckBox Content="Write Properties" IsChecked="{Binding CanWriteProperties}" />
                <CheckBox Content="Write Content" IsChecked="{Binding CanWriteContent}" />
                <CheckBox Content="Bind" IsChecked="{Binding CanBind}" />
                <CheckBox Content="Unbind" IsChecked="{Binding CanUnbind}" />
                <CheckBox Content="Unlock" IsChecked="{Binding CanUnlock}" />
            </StackPanel>

            <!-- Admin Privileges -->
            <StackPanel Spacing="4" Margin="0,8,0,0">
                <CheckBox Content="Write ACL" IsChecked="{Binding CanWriteAcl}" />
            </StackPanel>
        </StackPanel>

        <!-- Grant/Deny Toggle -->
        <StackPanel Spacing="8" Margin="0,20,0,0">
            <TextBlock Text="Action:" FontWeight="SemiBold" FontSize="16" />
            <StackPanel Orientation="Horizontal" Spacing="16">
                <RadioButton Content="Grant" GroupName="GrantDeny" IsChecked="{Binding IsGrant}" />
                <RadioButton Content="Deny" GroupName="GrantDeny" IsChecked="{Binding IsGrant, Converter={x:Static BoolConverters.Not}}" />
            </StackPanel>
        </StackPanel>

        <!-- Buttons -->
        <StackPanel Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Spacing="10"
                    Margin="0,20,0,0">
            <Button Content="Cancel"
                    Command="{Binding CancelCommand}"
                    Width="80"
                    Padding="0,8" />
            <Button Content="Save"
                    Command="{Binding SaveCommand}"
                    Width="80"
                    Padding="0,8"
                    Classes="Accent" />
        </StackPanel>
    </StackPanel>

</Window>
