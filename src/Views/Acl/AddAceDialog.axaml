<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:acl="using:perinma.Views.Acl"
        xmlns:calDav="using:perinma.Services.CalDAV"
        x:DataType="acl:AddAceDialogViewModel"
        mc:Ignorable="d" d:DesignWidth="500" d:DesignHeight="500"
        x:Class="perinma.Views.Acl.AddAceDialog"
        Title="Add Permission"
        Width="500"
        MaxWidth="600"
        MaxHeight="700"
        CanResize="False"
        SizeToContent="WidthAndHeight"
        WindowStartupLocation="CenterOwner">

    <DockPanel Margin="20">
        <!-- Principal Selection -->
        <StackPanel DockPanel.Dock="Top" Spacing="12">
            <TextBlock Text="Who should have access?" FontWeight="SemiBold" />

            <!-- Principal Type Selection -->
            <ComboBox Name="PrincipalTypeComboBox"
                      ItemsSource="{Binding PrincipalTypes}"
                      SelectedIndex="{Binding SelectedPrincipalTypeIndex}">
                <ComboBox.ItemTemplate>
                    <DataTemplate x:DataType="acl:PrincipalTypeItem">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <TextBlock Text="{Binding Icon}" />
                            <TextBlock Text="{Binding DisplayName}" />
                        </StackPanel>
                    </DataTemplate>
                </ComboBox.ItemTemplate>
            </ComboBox>

            <!-- URL input and principal search for Href principals -->
            <StackPanel IsVisible="{Binding ShowUrlInput}" Spacing="8">
                <StackPanel IsVisible="{Binding CanSearchPrincipals}" Spacing="8">
                    <!-- Search Box -->
                    <StackPanel Spacing="4">
                        <TextBlock Text="Search for users/groups:" FontSize="12" />
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <TextBox Text="{Binding SearchTerm, UpdateSourceTrigger=PropertyChanged}"
                                     Watermark="Search by name..."
                                     Width="300" />
                            <TextBlock Text="Searching..."
                                       IsVisible="{Binding IsSearching}"
                                       VerticalAlignment="Center"
                                       Foreground="Gray" />
                        </StackPanel>
                    </StackPanel>

                    <!-- Search Results -->
                    <ScrollViewer MaxHeight="120"
                                  VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled"
                                  IsVisible="{Binding HasSearchResults}">
                        <Border BorderBrush="Gray"
                                BorderThickness="1"
                                CornerRadius="4"
                                Padding="8">
                            <ItemsControl ItemsSource="{Binding SearchResults}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="calDav:PrincipalSearchResult">
                                        <Border Padding="8"
                                                Margin="0,0,0,4"
                                                BorderBrush="LightGray"
                                                BorderThickness="0,0,0,1"
                                                Cursor="Hand"
                                                PointerPressed="OnSearchResultPointerPressed">
                                            <Border.Styles>
                                                <Style Selector="Border:pointerover">
                                                    <Setter Property="Background" Value="#F0F0F0" />
                                                </Style>
                                            </Border.Styles>
                                            <StackPanel Spacing="4">
                                                <StackPanel Orientation="Horizontal" Spacing="8">
                                                    <TextBlock Text="{Binding DisplayName}"
                                                               FontWeight="SemiBold" />
                                                    <TextBlock Text="(Group)"
                                                               IsVisible="{Binding IsGroup}"
                                                               FontSize="11"
                                                               Foreground="Gray" />
                                                </StackPanel>
                                                <TextBlock Text="{Binding Email}"
                                                           FontSize="11"
                                                           Foreground="Gray"
                                                           IsVisible="{Binding HasEmail}" />
                                                <TextBlock Text="{Binding Href}"
                                                           FontSize="10"
                                                           Foreground="Silver"
                                                           TextTrimming="CharacterEllipsis" />
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </Border>
                    </ScrollViewer>

                    <Button Content="Clear Search"
                            Command="{Binding ClearPrincipalSelectionCommand}"
                            HorizontalAlignment="Left"
                            Padding="12,6"
                            IsVisible="{Binding HasPrincipalUrl}" />
                </StackPanel>

                <!-- Manual URL input (always available as fallback) -->
                <StackPanel Spacing="4" Margin="0,8,0,0">
                    <TextBlock Text="Or enter URL manually:" FontSize="12" Foreground="Gray" />
                    <TextBox Text="{Binding PrincipalUrl, UpdateSourceTrigger=PropertyChanged}"
                             Watermark="https://server.com/principals/users/username" />
                </StackPanel>
            </StackPanel>
        </StackPanel>

        <!-- Privilege Selection -->
        <StackPanel DockPanel.Dock="Top" Spacing="12" Margin="0,16,0,0">
            <TextBlock Text="What permissions?" FontWeight="SemiBold" />

            <!-- Preset Buttons -->
            <StackPanel Orientation="Horizontal" Spacing="8">
                <Button Content="Read Only"
                        Command="{Binding SetPresetCommand}"
                        CommandParameter="Read"
                        Padding="12,6" />
                <Button Content="Read/Write"
                        Command="{Binding SetPresetCommand}"
                        CommandParameter="ReadWrite"
                        Padding="12,6" />
                <Button Content="Full Access"
                        Command="{Binding SetPresetCommand}"
                        CommandParameter="Full"
                        Padding="12,6" />
            </StackPanel>
        </StackPanel>

        <!-- Custom Privileges (scrollable) -->
        <ScrollViewer DockPanel.Dock="Top"
                    VerticalScrollBarVisibility="Auto"
                    HorizontalScrollBarVisibility="Disabled"
                    MaxHeight="250"
                    Margin="0,8,0,0">
            <Border BorderBrush="Gray"
                    BorderThickness="1"
                    CornerRadius="4"
                    Padding="12">
                <StackPanel Spacing="8">
                    <TextBlock Text="Custom privileges:" FontSize="12" FontWeight="SemiBold" />

                    <!-- Read Privileges -->
                    <StackPanel Spacing="4">
                        <CheckBox Content="Read" IsChecked="{Binding CanRead}" />
                        <CheckBox Content="Read ACL" IsChecked="{Binding CanReadAcl}" />
                    </StackPanel>

                    <!-- Write Privileges -->
                    <StackPanel Spacing="4" Margin="0,4,0,0">
                        <CheckBox Content="Write" IsChecked="{Binding CanWrite}" />
                        <CheckBox Content="Write Properties" IsChecked="{Binding CanWriteProperties}" />
                        <CheckBox Content="Write Content" IsChecked="{Binding CanWriteContent}" />
                        <CheckBox Content="Bind" IsChecked="{Binding CanBind}" />
                        <CheckBox Content="Unbind" IsChecked="{Binding CanUnbind}" />
                        <CheckBox Content="Unlock" IsChecked="{Binding CanUnlock}" />
                    </StackPanel>

                    <!-- Admin Privileges -->
                    <StackPanel Spacing="4" Margin="0,4,0,0">
                        <CheckBox Content="Write ACL" IsChecked="{Binding CanWriteAcl}" />
                    </StackPanel>
                </StackPanel>
            </Border>
        </ScrollViewer>

        <!-- Grant/Deny Toggle -->
        <StackPanel DockPanel.Dock="Top" Spacing="8" Margin="0,16,0,0">
            <TextBlock Text="Action:" FontWeight="SemiBold" />
            <StackPanel Orientation="Horizontal" Spacing="16">
                <RadioButton Content="Grant" GroupName="GrantDeny" IsChecked="{Binding IsGrant}" />
                <RadioButton Content="Deny" GroupName="GrantDeny" IsChecked="{Binding IsGrant, Converter={x:Static BoolConverters.Not}}" />
            </StackPanel>
        </StackPanel>

        <!-- Buttons -->
        <StackPanel DockPanel.Dock="Bottom"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Spacing="10"
                    Margin="0,20,0,0">
            <Button Content="Cancel"
                    Command="{Binding CancelCommand}"
                    Width="80"
                    Padding="0,8" />
            <Button Content="Add"
                    Command="{Binding AddCommand}"
                    Width="80"
                    Padding="0,8"
                    Classes="Accent" />
        </StackPanel>
    </DockPanel>

</Window>
