<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:ev="clr-namespace:perinma.Views.Calendar.EventView"
             xmlns:html="clr-namespace:TheArtOfDev.HtmlRenderer.Avalonia;assembly=Avalonia.HtmlRenderer"
             mc:Ignorable="d" d:DesignWidth="300" d:DesignHeight="150"
             x:Class="perinma.Views.Calendar.EventView.RichTextView"
             x:DataType="ev:RichTextViewModel">
    
    <StackPanel Spacing="4">
        <TextBlock Text="{Binding Title}" FontWeight="SemiBold"/>
        <html:HtmlPanel x:Name="HtmlPanel"
                        Text="{Binding HtmlText}"
                        MaxHeight="200"
                        MaxWidth="400"
                        IsVisible="{Binding IsHtml}" />
        <TextBlock Text="{Binding SimpleText}"
                   TextWrapping="Wrap"
                   IsVisible="{Binding !IsHtml}" />
    </StackPanel>

</UserControl>
