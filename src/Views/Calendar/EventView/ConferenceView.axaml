<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:ev="clr-namespace:perinma.Views.Calendar.EventView"
             xmlns:cm="clr-namespace:perinma.Views.Common"
             mc:Ignorable="d" d:DesignWidth="300" d:DesignHeight="150"
             x:Class="perinma.Views.Calendar.EventView.ConferenceView"
             x:DataType="ev:ConferenceViewModel">

    <StackPanel Spacing="4">
        <TextBlock Text="Conference" FontWeight="SemiBold" />
        <StackPanel Orientation="Horizontal" Spacing="4">
            <TextBlock Text="{Binding Name}" />
            <ItemsControl ItemsSource="{Binding EntryPoints}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="ev:ConferenceEntryPointViewModel">
                        <cm:Hyperlink DisplayText="{Binding Label}" Uri="{Binding Uri}" />
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <StackPanel Orientation="Horizontal" Spacing="4"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
            </ItemsControl>
        </StackPanel>
    </StackPanel>
</UserControl>