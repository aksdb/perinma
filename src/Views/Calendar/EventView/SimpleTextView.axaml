<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:ev="clr-namespace:perinma.Views.Calendar.EventView"
             mc:Ignorable="d" d:DesignWidth="250" d:DesignHeight="50"
             x:Class="perinma.Views.Calendar.EventView.SimpleTextView"
             x:DataType="ev:SimpleTextViewModel">
    
    <Design.DataContext>
        <ev:SimpleTextViewModel/>
    </Design.DataContext>
    
    <StackPanel Orientation="Vertical">
        <TextBlock Text="{Binding Label}" FontWeight="Bold"/>
        <TextBlock Text="{Binding Content}"/>
    </StackPanel>
</UserControl>
