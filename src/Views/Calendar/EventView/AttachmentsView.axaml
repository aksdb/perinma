<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:ev="clr-namespace:perinma.Views.Calendar.EventView"
             xmlns:cm="clr-namespace:perinma.Views.Common"
             mc:Ignorable="d" d:DesignWidth="300" d:DesignHeight="100"
             x:Class="perinma.Views.Calendar.EventView.AttachmentsView"
             x:DataType="ev:AttachmentsViewModel">

    <StackPanel Spacing="4">
        <TextBlock Text="Attachments" FontWeight="SemiBold" />
        <ItemsControl ItemsSource="{Binding Attachments}">
            <ItemsControl.ItemTemplate>
                <DataTemplate x:DataType="ev:AttachmentItemViewModel">
                    <cm:Hyperlink Uri="{Binding Url}" DisplayText="{Binding Title}"/>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>
    </StackPanel>

</UserControl>