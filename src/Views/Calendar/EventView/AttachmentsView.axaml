<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:ev="clr-namespace:perinma.Views.Calendar.EventView"
             mc:Ignorable="d" d:DesignWidth="300" d:DesignHeight="100"
             x:Class="perinma.Views.Calendar.EventView.AttachmentsView"
             x:DataType="ev:AttachmentsViewModel">

    <StackPanel Spacing="4">
        <TextBlock Text="Attachments" FontWeight="SemiBold" />
        <ItemsControl ItemsSource="{Binding Attachments}">
            <ItemsControl.ItemTemplate>
                <DataTemplate x:DataType="ev:AttachmentItemViewModel">
                    <StackPanel
                        ToolTip.Tip="{Binding Url}">
                        <TextBlock Text="{Binding Title}"
                                   Foreground="Blue"
                                   TextWrapping="Wrap"
                                   Cursor="Hand"
                                   TextDecorations="Underline"
                                   Margin="0,2,0,2"
                                   Tag="{Binding Url}"
                                   PointerPressed="OnAttachmentPointerPressed">
                        </TextBlock>
                        <StackPanel.ContextMenu>
                            <ContextMenu>
                                <MenuItem Header="Open" Command="{Binding OpenUrlCommand}" />
                                <MenuItem Header="Copy" Command="{Binding CopyUrlCommand}" />
                            </ContextMenu>
                        </StackPanel.ContextMenu>
                    </StackPanel>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>
    </StackPanel>

</UserControl>