<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:ev="using:perinma.Views.Calendar.EventView"
             x:DataType="ev:ParticipantViewModel"
             mc:Ignorable="d" d:DesignWidth="280" d:DesignHeight="32"
             x:Class="perinma.Views.Calendar.EventView.ParticipantView">

    <Border Padding="4,3" Background="Transparent" CornerRadius="4">
        <Border.Styles>
            <Style Selector="Border:pointerover">
                <Setter Property="Background" Value="{DynamicResource SystemControlBackgroundListLowBrush}" />
            </Style>
        </Border.Styles>
        <FlyoutBase.AttachedFlyout>
            <Flyout Placement="Right" ShowMode="TransientWithDismissOnPointerMoveAway">
                <Border Padding="12" MinWidth="240" MaxWidth="300">
                    <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto,Auto">
                        <Border Grid.RowSpan="2" Width="48" Height="48" CornerRadius="24"
                                Background="{DynamicResource SystemAccentColorLight2}"
                                Margin="0,0,12,0" VerticalAlignment="Top">
                            <Panel>
                                <Image Source="{Binding PhotoBitmap}" Stretch="UniformToFill"
                                       IsVisible="{Binding HasPhoto}" />
                                <TextBlock Text="{Binding Initials}" FontSize="16" FontWeight="SemiBold"
                                           Foreground="White" HorizontalAlignment="Center"
                                           VerticalAlignment="Center" IsVisible="{Binding !HasPhoto}" />
                            </Panel>
                        </Border>
                        
                        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8">
                            <TextBlock Text="{Binding DisplayName}"
                                       FontSize="14"
                                       FontWeight="SemiBold"
                                       TextWrapping="Wrap" />
                            <TextBlock Text="{Binding StatusIcon}"
                                       Foreground="{Binding StatusColor}"
                                       FontWeight="Bold"
                                       VerticalAlignment="Center"
                                       ToolTip.Tip="{Binding StatusTooltip}"
                                       IsVisible="{Binding HasStatus}" />
                        </StackPanel>
                        
                        <TextBlock Grid.Column="1" Grid.Row="1"
                                   Text="{Binding Email}"
                                   FontSize="12"
                                   Foreground="Gray"
                                   TextWrapping="Wrap"
                                   Margin="0,2,0,0" />
                        
                        <TextBlock Grid.Column="1" Grid.Row="2"
                                   Text="Organizer"
                                   FontSize="11"
                                   Foreground="{DynamicResource SystemControlHighlightAltBrush}"
                                   IsVisible="{Binding IsOrganizer}"
                                   Margin="0,4,0,0" />
                    </Grid>
                </Border>
            </Flyout>
        </FlyoutBase.AttachedFlyout>
        <Grid ColumnDefinitions="28,16,*" PointerEntered="OnPointerEntered">
            <Border Width="24" Height="24" CornerRadius="12"
                    Background="{DynamicResource SystemAccentColorLight2}">
                <Panel>
                    <Image Source="{Binding PhotoBitmap}" Stretch="UniformToFill"
                           IsVisible="{Binding HasPhoto}" />
                    <TextBlock Text="{Binding Initials}" FontSize="9" FontWeight="SemiBold"
                               Foreground="White" HorizontalAlignment="Center"
                               VerticalAlignment="Center" IsVisible="{Binding !HasPhoto}" />
                </Panel>
            </Border>
            
            <TextBlock Grid.Column="1"
                       Text="{Binding StatusIcon}"
                       Foreground="{Binding StatusColor}"
                       FontWeight="Bold"
                       VerticalAlignment="Center"
                       HorizontalAlignment="Center"
                       ToolTip.Tip="{Binding StatusTooltip}"
                       IsVisible="{Binding HasStatus}" />
            
            <TextBlock Grid.Column="2"
                       Text="{Binding DisplayName}"
                       VerticalAlignment="Center"
                       TextTrimming="CharacterEllipsis"
                       Margin="4,0,0,0" />
        </Grid>
    </Border>

</UserControl>
