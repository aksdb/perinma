<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:cal="using:perinma.Views.Calendar"
             xmlns:models="using:perinma.Models"
             xmlns:html="clr-namespace:TheArtOfDev.HtmlRenderer.Avalonia;assembly=Avalonia.HtmlRenderer"
             x:DataType="cal:GoogleCalendarEventViewModel"
             mc:Ignorable="d" d:DesignWidth="350" d:DesignHeight="200"
             x:Class="perinma.Views.Calendar.GoogleCalendarEventView">

    <StackPanel Spacing="8" Margin="12">
        <TextBlock Text="Loading event details..." IsVisible="{Binding IsLoading}" />

        <StackPanel Spacing="8" IsVisible="{Binding !IsLoading}">
            <TextBlock Text="{Binding CalendarEvent.Title}" FontWeight="Bold" FontSize="14" />

            <Separator />

            <StackPanel Orientation="Horizontal" Spacing="4">
                <TextBlock Text="Start: " FontWeight="SemiBold" FontSize="12" />
                <TextBlock Text="{Binding CalendarEvent.StartTime}" />
            </StackPanel>
            <StackPanel Orientation="Horizontal" Spacing="4">
                <TextBlock Text="End: " FontWeight="SemiBold" FontSize="12" />
                <TextBlock Text="{Binding CalendarEvent.EndTime}" />
            </StackPanel>

            <StackPanel Spacing="4" IsVisible="{Binding GoogleMeetLink, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
                <TextBlock Text="Google Meet" FontWeight="SemiBold" FontSize="12" />
                <TextBlock Text="{Binding GoogleMeetLink}" Foreground="Blue" TextWrapping="Wrap"
                           Cursor="Hand" TextDecorations="Underline"
                           PointerPressed="OnGoogleMeetLinkPressed" />
            </StackPanel>

            <StackPanel Spacing="4" IsVisible="{Binding Location, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
                <TextBlock Text="Location" FontWeight="SemiBold" FontSize="12" />
                <TextBlock Text="{Binding Location}" TextWrapping="Wrap" />
            </StackPanel>

            <StackPanel Spacing="4" IsVisible="{Binding Description, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
                <TextBlock Text="Description" FontWeight="SemiBold" FontSize="12" />
                <html:HtmlPanel x:Name="DescriptionHtmlPanel"
                                Text="{Binding Description}" 
                                MaxHeight="200" 
                                MaxWidth="400"
                                />
            </StackPanel>

            <StackPanel Spacing="4" IsVisible="{Binding HasOrganizer}">
                <TextBlock Text="Organizer" FontWeight="SemiBold" FontSize="12" />
                <Border Padding="4,3" Background="Transparent" CornerRadius="4"
                        DataContext="{Binding Organizer}">
                    <Border.Styles>
                        <Style Selector="Border:pointerover">
                            <Setter Property="Background" Value="{DynamicResource SystemControlBackgroundListLowBrush}" />
                        </Style>
                    </Border.Styles>
                    <FlyoutBase.AttachedFlyout>
                        <Flyout Placement="Right" ShowMode="TransientWithDismissOnPointerMoveAway">
                            <Border Padding="12" MinWidth="240" MaxWidth="300">
                                <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto">
                                    <Border Grid.RowSpan="2" Width="48" Height="48" CornerRadius="24"
                                            Background="{DynamicResource SystemAccentColorLight2}"
                                            Margin="0,0,12,0" VerticalAlignment="Top">
                                        <Panel>
                                            <Image Source="{Binding PhotoBitmap}" Stretch="UniformToFill"
                                                   IsVisible="{Binding HasPhoto}" />
                                            <TextBlock Text="{Binding Initials}" FontSize="16" FontWeight="SemiBold"
                                                       Foreground="White" HorizontalAlignment="Center"
                                                       VerticalAlignment="Center" IsVisible="{Binding !HasPhoto}" />
                                        </Panel>
                                    </Border>
                                    <TextBlock Grid.Column="1" Text="{Binding DisplayName}"
                                               FontSize="14" FontWeight="SemiBold" TextWrapping="Wrap" />
                                    <TextBlock Grid.Column="1" Grid.Row="1" Text="{Binding Email}"
                                               FontSize="12" Foreground="Gray" TextWrapping="Wrap" Margin="0,2,0,0" />
                                </Grid>
                            </Border>
                        </Flyout>
                    </FlyoutBase.AttachedFlyout>
                    <Grid ColumnDefinitions="28,*" PointerEntered="OnContactPointerEntered">
                        <Border Width="24" Height="24" CornerRadius="12"
                                Background="{DynamicResource SystemAccentColorLight2}">
                            <Panel>
                                <Image Source="{Binding PhotoBitmap}" Stretch="UniformToFill"
                                       IsVisible="{Binding HasPhoto}" />
                                <TextBlock Text="{Binding Initials}" FontSize="9" FontWeight="SemiBold"
                                           Foreground="White" HorizontalAlignment="Center"
                                           VerticalAlignment="Center" IsVisible="{Binding !HasPhoto}" />
                            </Panel>
                        </Border>
                        <TextBlock Grid.Column="1" Text="{Binding DisplayName}"
                                   VerticalAlignment="Center" Margin="4,0,0,0" />
                    </Grid>
                </Border>
            </StackPanel>

            <StackPanel Spacing="4" IsVisible="{Binding HasCreator}">
                <TextBlock Text="Created by" FontWeight="SemiBold" FontSize="12" />
                <Border Padding="4,3" Background="Transparent" CornerRadius="4"
                        DataContext="{Binding Creator}">
                    <Border.Styles>
                        <Style Selector="Border:pointerover">
                            <Setter Property="Background" Value="{DynamicResource SystemControlBackgroundListLowBrush}" />
                        </Style>
                    </Border.Styles>
                    <FlyoutBase.AttachedFlyout>
                        <Flyout Placement="Right" ShowMode="TransientWithDismissOnPointerMoveAway">
                            <Border Padding="12" MinWidth="240" MaxWidth="300">
                                <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto">
                                    <Border Grid.RowSpan="2" Width="48" Height="48" CornerRadius="24"
                                            Background="{DynamicResource SystemAccentColorLight2}"
                                            Margin="0,0,12,0" VerticalAlignment="Top">
                                        <Panel>
                                            <Image Source="{Binding PhotoBitmap}" Stretch="UniformToFill"
                                                   IsVisible="{Binding HasPhoto}" />
                                            <TextBlock Text="{Binding Initials}" FontSize="16" FontWeight="SemiBold"
                                                       Foreground="White" HorizontalAlignment="Center"
                                                       VerticalAlignment="Center" IsVisible="{Binding !HasPhoto}" />
                                        </Panel>
                                    </Border>
                                    <TextBlock Grid.Column="1" Text="{Binding DisplayName}"
                                               FontSize="14" FontWeight="SemiBold" TextWrapping="Wrap" />
                                    <TextBlock Grid.Column="1" Grid.Row="1" Text="{Binding Email}"
                                               FontSize="12" Foreground="Gray" TextWrapping="Wrap" Margin="0,2,0,0" />
                                </Grid>
                            </Border>
                        </Flyout>
                    </FlyoutBase.AttachedFlyout>
                    <Grid ColumnDefinitions="28,*" PointerEntered="OnContactPointerEntered">
                        <Border Width="24" Height="24" CornerRadius="12"
                                Background="{DynamicResource SystemAccentColorLight2}">
                            <Panel>
                                <Image Source="{Binding PhotoBitmap}" Stretch="UniformToFill"
                                       IsVisible="{Binding HasPhoto}" />
                                <TextBlock Text="{Binding Initials}" FontSize="9" FontWeight="SemiBold"
                                           Foreground="White" HorizontalAlignment="Center"
                                           VerticalAlignment="Center" IsVisible="{Binding !HasPhoto}" />
                            </Panel>
                        </Border>
                        <TextBlock Grid.Column="1" Text="{Binding DisplayName}"
                                   VerticalAlignment="Center" Margin="4,0,0,0" />
                    </Grid>
                </Border>
            </StackPanel>

            <StackPanel Spacing="4" IsVisible="{Binding Attendees.Count}">
                <TextBlock Text="Attendees" FontWeight="SemiBold" FontSize="12" />
                <ScrollViewer MaxHeight="220" VerticalScrollBarVisibility="Auto">
                    <ItemsControl ItemsSource="{Binding Attendees}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="cal:AttendeeViewModel">
                                <Border Padding="4,3" Margin="0,1" Background="Transparent"
                                        CornerRadius="4">
                                    <Border.Styles>
                                        <Style Selector="Border:pointerover">
                                            <Setter Property="Background" Value="{DynamicResource SystemControlBackgroundListLowBrush}" />
                                        </Style>
                                    </Border.Styles>
                                    <FlyoutBase.AttachedFlyout>
                                        <Flyout Placement="Right" ShowMode="TransientWithDismissOnPointerMoveAway">
                                            <Border Padding="12" MinWidth="240" MaxWidth="300">
                                                <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto">
                                                    <!-- Avatar -->
                                                    <Border Grid.RowSpan="2"
                                                            Width="48" Height="48"
                                                            CornerRadius="24"
                                                            Background="{DynamicResource SystemAccentColorLight2}"
                                                            Margin="0,0,12,0"
                                                            VerticalAlignment="Top">
                                                        <Panel>
                                                            <Image Source="{Binding PhotoBitmap}"
                                                                   Stretch="UniformToFill"
                                                                   IsVisible="{Binding HasPhoto}" />
                                                            <TextBlock Text="{Binding Initials}"
                                                                       FontSize="16"
                                                                       FontWeight="SemiBold"
                                                                       Foreground="White"
                                                                       HorizontalAlignment="Center"
                                                                       VerticalAlignment="Center"
                                                                       IsVisible="{Binding !HasPhoto}" />
                                                        </Panel>
                                                    </Border>
                                                    
                                                    <!-- Name and status -->
                                                    <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8">
                                                        <TextBlock Text="{Binding DisplayName}"
                                                                   FontSize="14"
                                                                   FontWeight="SemiBold"
                                                                   TextWrapping="Wrap" />
                                                        <TextBlock Text="{Binding StatusIcon}"
                                                                   Foreground="{Binding StatusColor}"
                                                                   FontWeight="Bold"
                                                                   VerticalAlignment="Center"
                                                                   ToolTip.Tip="{Binding StatusTooltip}" />
                                                    </StackPanel>
                                                    
                                                    <!-- Email -->
                                                    <TextBlock Grid.Column="1" Grid.Row="1"
                                                               Text="{Binding Email}"
                                                               FontSize="12"
                                                               Foreground="Gray"
                                                               TextWrapping="Wrap"
                                                               Margin="0,2,0,0" />
                                                </Grid>
                                            </Border>
                                        </Flyout>
                                    </FlyoutBase.AttachedFlyout>
                                    <Grid ColumnDefinitions="28,16,*" PointerEntered="OnAttendeePointerEntered">
                                        <!-- Avatar (small) - fixed 24px + 4px spacing -->
                                        <Border Width="24" Height="24"
                                                CornerRadius="12"
                                                Background="{DynamicResource SystemAccentColorLight2}">
                                            <Panel>
                                                <Image Source="{Binding PhotoBitmap}"
                                                       Stretch="UniformToFill"
                                                       IsVisible="{Binding HasPhoto}" />
                                                <TextBlock Text="{Binding Initials}"
                                                           FontSize="9"
                                                           FontWeight="SemiBold"
                                                           Foreground="White"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center"
                                                           IsVisible="{Binding !HasPhoto}" />
                                            </Panel>
                                        </Border>
                                        
                                        <!-- Status icon - fixed 16px width for alignment -->
                                        <TextBlock Grid.Column="1"
                                                   Text="{Binding StatusIcon}"
                                                   Foreground="{Binding StatusColor}"
                                                   FontWeight="Bold"
                                                   VerticalAlignment="Center"
                                                   HorizontalAlignment="Center"
                                                   ToolTip.Tip="{Binding StatusTooltip}" />
                                        
                                        <!-- Name - starts at fixed position -->
                                        <TextBlock Grid.Column="2"
                                                   Text="{Binding DisplayName}"
                                                   VerticalAlignment="Center"
                                                   TextTrimming="CharacterEllipsis"
                                                   Margin="4,0,0,0" />
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </StackPanel>

            <StackPanel Spacing="4" IsVisible="{Binding Attachments.Count}">
                <TextBlock Text="Attachments" FontWeight="SemiBold" FontSize="12" />
                <ItemsControl ItemsSource="{Binding Attachments}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="cal:EventAttachment">
                            <TextBlock Text="{Binding Title}" 
                                       Foreground="Blue" 
                                       TextWrapping="Wrap"
                                       Cursor="Hand" 
                                       TextDecorations="Underline"
                                       Margin="0,2,0,2"
                                       Tag="{Binding FileUrl}"
                                       PointerPressed="OnAttachmentLinkPressed" />
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>

            <!-- Response buttons -->
            <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,8,0,0" IsVisible="{Binding CanRespond}">
                <Button Content="Accept" 
                        Command="{Binding AcceptEventCommand}"
                        IsEnabled="{Binding !IsUpdating}"
                        Classes="accent" />
                <Button Content="Tentative" 
                        Command="{Binding TentativeEventCommand}"
                        IsEnabled="{Binding !IsUpdating}" />
                <Button Content="Decline" 
                        Command="{Binding DeclineEventCommand}"
                        IsEnabled="{Binding !IsUpdating}" />
            </StackPanel>
            
            <TextBlock Text="Updating..." IsVisible="{Binding IsUpdating}" FontStyle="Italic" Opacity="0.7" />
        </StackPanel>
    </StackPanel>

</UserControl>
