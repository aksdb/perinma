<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:cal="using:perinma.Views.Calendar"
        mc:Ignorable="d" d:DesignWidth="500" d:DesignHeight="550"
        x:Class="perinma.Views.Calendar.EventEditView"
        x:DataType="cal:EventEditViewModel"
        Title="{Binding WindowTitle}"
        Width="500" Height="550"
        WindowStartupLocation="CenterOwner">

    <Window.Resources>
        <cal:DateTimeToTimeSpanConverter x:Key="DateTimeToTimeSpanConverter"/>
    </Window.Resources>

    <Grid RowDefinitions="Auto,*,Auto" Margin="16">
        <StackPanel Grid.Row="0" Spacing="12">
            <!-- Calendar Selection -->
            <StackPanel Spacing="4">
                <TextBlock Text="Calendar" FontWeight="SemiBold" FontSize="12"/>
                <ComboBox ItemsSource="{Binding Calendars}"
                          SelectedItem="{Binding SelectedCalendar}"
                          HorizontalAlignment="Stretch"
                          PlaceholderText="Select Calendar">
                    <ComboBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <Ellipse Width="12" Height="12" Fill="{Binding Color}" Stroke="{DynamicResource SystemControlForegroundBrush}"/>
                                <TextBlock Text="{Binding Name}" VerticalAlignment="Center"/>
                            </StackPanel>
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>
            </StackPanel>

            <!-- Title -->
            <StackPanel Spacing="4">
                <TextBlock Text="Title" FontWeight="SemiBold" FontSize="12"/>
                <TextBox Text="{Binding Title}"
                         Watermark="Event title"
                         HorizontalAlignment="Stretch"/>
            </StackPanel>

            <!-- Date/Time Section -->
            <StackPanel Spacing="8">
                <!-- Start Date/Time -->
                <StackPanel Spacing="4">
                    <TextBlock Text="Start" FontWeight="SemiBold" FontSize="12"/>
                    <Grid ColumnDefinitions="*,8,*">
                        <CalendarDatePicker Name="StartDatePicker"
                                        SelectedDate="{Binding StartTime}"
                                        HorizontalAlignment="Stretch"
                                        IsTodayHighlighted="True"/>
                        <TimePicker Name="StartTimePicker"
                                   Grid.Column="2"
                                   ClockIdentifier="24HourClock"
                                   SelectedTime="{Binding StartTime, Converter={StaticResource DateTimeToTimeSpanConverter}}"
                                   HorizontalAlignment="Stretch"/>
                    </Grid>
                </StackPanel>

                <!-- End Date/Time -->
                <StackPanel Spacing="4">
                    <TextBlock Text="End" FontWeight="SemiBold" FontSize="12"/>
                    <Grid ColumnDefinitions="*,8,*">
                        <CalendarDatePicker Name="EndDatePicker"
                                        SelectedDate="{Binding EndTime}"
                                        HorizontalAlignment="Stretch"
                                        IsTodayHighlighted="True"/>
                        <TimePicker Name="EndTimePicker"
                                   Grid.Column="2"
                                   ClockIdentifier="24HourClock"
                                   SelectedTime="{Binding EndTime, Converter={StaticResource DateTimeToTimeSpanConverter}}"
                                   HorizontalAlignment="Stretch"/>
                    </Grid>
                </StackPanel>
            </StackPanel>

            <!-- Description -->
            <StackPanel Spacing="4">
                <TextBlock Text="Description" FontWeight="SemiBold" FontSize="12"/>
                <TextBox Text="{Binding Description}"
                         Watermark="Description (optional)"
                         AcceptsReturn="True"
                         TextWrapping="Wrap"
                         HorizontalAlignment="Stretch"
                         Height="80"/>
            </StackPanel>

            <!-- Location -->
            <StackPanel Spacing="4">
                <TextBlock Text="Location" FontWeight="SemiBold" FontSize="12"/>
                <TextBox Text="{Binding Location}"
                         Watermark="Location (optional)"
                         HorizontalAlignment="Stretch"/>
            </StackPanel>
        </StackPanel>

        <!-- Error Message -->
        <Border Grid.Row="2" 
                BorderBrush="{DynamicResource SystemChromeLowColor}" 
                BorderThickness="0,1,0,0" 
                Padding="0,0,0,12" 
                IsVisible="{Binding ErrorMessage}">
            <TextBlock Text="{Binding ErrorMessage}" 
                       Foreground="{DynamicResource SystemErrorColorBrush}" 
                       FontSize="12" 
                       TextWrapping="Wrap"/>
        </Border>

        <!-- Buttons -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right">
            <Button Content="Save" 
                    Command="{Binding SaveCommand}" 
                    IsEnabled="{Binding !IsSaving}"
                    MinWidth="100"
                    HorizontalAlignment="Right"
                    Margin="0,0,0,12"/>
            <Button Content="Cancel" 
                    Command="{Binding CancelCommand}" 
                    MinWidth="100"
                    HorizontalAlignment="Right"
                    Margin="0,0,0,12"/>
        </StackPanel>
    </Grid>
</Window>
