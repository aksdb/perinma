<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:cal="using:perinma.Views.Calendar"
        mc:Ignorable="d" d:DesignWidth="500" d:DesignHeight="450"
        x:Class="perinma.Views.Calendar.EventEditView"
        x:DataType="cal:EventEditViewModel"
        Title="{Binding WindowTitle}"
        Width="500" Height="500"
        WindowStartupLocation="CenterOwner">

    <Design.DataContext>
        <cal:EventEditViewModel/>
    </Design.DataContext>

    <Grid RowDefinitions="Auto,*,Auto" Margin="16">
        <StackPanel Grid.Row="0" Spacing="8">
            <TextBlock Text="Title" FontSize="16" FontWeight="SemiBold"/>

            <ComboBox ItemsSource="{Binding Calendars}"
                      SelectedIndex="0"
                      HorizontalAlignment="Stretch"
                      PlaceholderText="Select Calendar">
                <ComboBox.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <Ellipse Width="12" Height="12" Fill="{Binding Color}" Stroke="{DynamicResource SystemControlForegroundBrush}"/>
                            <TextBlock Text="{Binding Name}" VerticalAlignment="Center"/>
                        </StackPanel>
                    </DataTemplate>
                </ComboBox.ItemTemplate>
            </ComboBox>

            <TextBox Text="{Binding Title}"
                     Watermark="Event title"
                     HorizontalAlignment="Stretch"/>

            <TextBox Text="{Binding Description}"
                     Watermark="Description (optional)"
                     AcceptsReturn="True"
                     TextWrapping="Wrap"
                     HorizontalAlignment="Stretch"
                     Height="100"/>

            <TextBox Text="{Binding Location}"
                     Watermark="Location (optional)"
                     HorizontalAlignment="Stretch"/>
        </StackPanel>

        <StackPanel Grid.Row="1" Spacing="8" Orientation="Horizontal" HorizontalAlignment="Right">
            <TextBlock Text="{Binding StartTime, StringFormat='{}yyyy-MM-dd HH:mm'}" 
                       VerticalAlignment="Center" 
                       FontSize="12" 
                       Margin="8,0"/>
            <TextBlock Text="to" 
                       VerticalAlignment="Center" 
                       FontSize="12" 
                       Margin="8,0"/>
            <TextBlock Text="{Binding EndTime, StringFormat='{}yyyy-MM-dd HH:mm'}" 
                       VerticalAlignment="Center" 
                       FontSize="12" 
                       Margin="8,0"/>
        </StackPanel>

        <Border Grid.Row="2" 
                BorderBrush="{DynamicResource SystemChromeLowColor}" 
                BorderThickness="0,1,0,0" 
                Padding="0,0,0,12" 
                IsVisible="{Binding ErrorMessage}">
            <TextBlock Text="{Binding ErrorMessage}" 
                       Foreground="{DynamicResource SystemErrorColorBrush}" 
                       FontSize="12" 
                       TextWrapping="Wrap"/>
        </Border>

        <StackPanel Grid.Row="2" Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right">
            <Button Content="Save" 
                    Command="{Binding SaveCommand}" 
                    IsEnabled="{Binding !IsSaving}"
                    MinWidth="100"
                    HorizontalAlignment="Right"
                    Margin="0,0,0,12"/>
            <Button Content="Cancel" 
                    Command="{Binding CancelCommand}" 
                    MinWidth="100"
                    HorizontalAlignment="Right"
                    Margin="0,0,0,12"/>
        </StackPanel>
    </Grid>
</Window>
