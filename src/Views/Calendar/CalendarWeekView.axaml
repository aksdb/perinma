<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:cal="using:perinma.Views.Calendar"
             x:DataType="cal:CalendarWeekViewModel"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="perinma.Views.Calendar.CalendarWeekView">

    <UserControl.Resources>
        <x:Double x:Key="CalendarTimeHourFontSize">12</x:Double>
        <x:Double x:Key="CalendarTimeMinuteFontSize">9</x:Double>
    </UserControl.Resources>

    <UserControl.Styles>
        <!-- Template for TimeLabel templated control -->
        <Style Selector="cal|TimeLabel">
            <Setter Property="Template">
                <ControlTemplate>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <TextBlock FontSize="{DynamicResource CalendarTimeHourFontSize}"
                                   Foreground="Gray"
                                   VerticalAlignment="Top"
                                   Text="{Binding Hour, RelativeSource={RelativeSource TemplatedParent}, StringFormat={}{0:00}}" />
                        <TextBlock FontSize="{DynamicResource CalendarTimeMinuteFontSize}"
                                   Foreground="Gray"
                                   VerticalAlignment="Top"
                                   Margin="2,0,0,0"
                                   Text="{Binding Minute, RelativeSource={RelativeSource TemplatedParent}, StringFormat={}{0:00}}" />
                    </StackPanel>
                </ControlTemplate>
            </Setter>
        </Style>

        <!-- Template for EventChip templated control -->
        <Style Selector="cal|EventItem">
            <Setter Property="Template">
                <ControlTemplate>
                    <Grid>
                        <!-- Dashed border rectangle (only visible when needsResponse class is present) -->
                        <Rectangle Name="DashedBorder"
                                   RadiusX="10" RadiusY="10"
                                   StrokeThickness="2"
                                   Stroke="{Binding BorderBrush, RelativeSource={RelativeSource TemplatedParent}}"
                                   StrokeDashArray="4,2" />
                        
                         <Border Name="Border"
                                 CornerRadius="10"
                                 Background="{Binding BackgroundBrush, RelativeSource={RelativeSource TemplatedParent}}"
                                 Margin="1"
                                 Bounds="{Binding AvailableBounds, RelativeSource={RelativeSource TemplatedParent}, Mode=OneWayToSource}">
                             <Border.ContextMenu>
                                 <ContextMenu>
                                     <MenuItem Header="Respond" IsVisible="{Binding EventViewModel.CanRespond, RelativeSource={RelativeSource TemplatedParent}}">
                                         <MenuItem Header="Accept" Command="{Binding EventViewModel.AcceptEventCommand, RelativeSource={RelativeSource TemplatedParent}}" />
                                         <MenuItem Header="Tentative" Command="{Binding EventViewModel.TentativeEventCommand, RelativeSource={RelativeSource TemplatedParent}}" />
                                         <MenuItem Header="Decline" Command="{Binding EventViewModel.DeclineEventCommand, RelativeSource={RelativeSource TemplatedParent}}" />
                                     </MenuItem>
                                 </ContextMenu>
                             </Border.ContextMenu>
                              <StackPanel Orientation="Vertical" Spacing="1" Margin="5, 1, 5, 1">
                                  <TextBlock Name="TitleTextBlock"
                                             Text="{Binding Title, RelativeSource={RelativeSource TemplatedParent}}"
                                             FontWeight="Bold"
                                             TextTrimming="CharacterEllipsis"
                                             FontSize="{DynamicResource CalendarTimeHourFontSize}"
                                             Foreground="{Binding ForegroundBrush, RelativeSource={RelativeSource TemplatedParent}}" />

                                 <!-- Inline variant: single line with emoji and range -->
                                 <TextBlock
                                     IsVisible="{Binding ShowInlineTimes, RelativeSource={RelativeSource TemplatedParent}}"
                                     Text="{Binding InlineTimeText, RelativeSource={RelativeSource TemplatedParent}}"
                                     FontSize="{DynamicResource CalendarTimeMinuteFontSize}"
                                     Foreground="{Binding ForegroundBrush, RelativeSource={RelativeSource TemplatedParent}}"
                                     TextTrimming="None" />

                                 <!-- Stacked variant: start and end on separate lines -->
                                 <StackPanel Orientation="Vertical"
                                             IsVisible="{Binding ShowStackedTimes, RelativeSource={RelativeSource TemplatedParent}}"
                                             Spacing="0">
                                     <TextBlock
                                         Text="{Binding StartTimeText, RelativeSource={RelativeSource TemplatedParent}}"
                                         FontSize="{DynamicResource CalendarTimeMinuteFontSize}"
                                         Foreground="{Binding ForegroundBrush, RelativeSource={RelativeSource TemplatedParent}}" />
                                     <TextBlock
                                         Text="{Binding EndTimeText, RelativeSource={RelativeSource TemplatedParent}}"
                                         FontSize="{DynamicResource CalendarTimeMinuteFontSize}"
                                         Foreground="{Binding ForegroundBrush, RelativeSource={RelativeSource TemplatedParent}}" />
                                 </StackPanel>
                             </StackPanel>
                             <FlyoutBase.AttachedFlyout>
                                 <Flyout Placement="Right">
                                     <ContentControl Name="EventFlyoutContent" />
                                 </Flyout>
                             </FlyoutBase.AttachedFlyout>
                         </Border>
                    </Grid>
                </ControlTemplate>
            </Setter>
        </Style>

        <!-- Style to show dashed border for events needing response (pending or declined) -->
        <Style Selector="cal|EventItem.needsResponse /template/ Rectangle#DashedBorder">
            <Setter Property="IsVisible" Value="True" />
        </Style>

        <!-- Style to hide dashed border for accepted events -->
        <Style Selector="cal|EventItem:not(.needsResponse) /template/ Rectangle#DashedBorder">
            <Setter Property="IsVisible" Value="False" />
        </Style>

        <!-- Style to apply strikethrough to declined event titles -->
        <Style Selector="cal|EventItem.declined /template/ TextBlock#TitleTextBlock">
            <Setter Property="TextDecorations" Value="Strikethrough" />
        </Style>
    </UserControl.Styles>

    <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto,*">
        <!-- Navigation Bar -->
        <Grid Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2"
              Margin="0, 10, 0, 10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            
            <!-- View Mode Buttons (Left) -->
            <StackPanel Grid.Column="0"
                        Orientation="Horizontal"
                        HorizontalAlignment="Left"
                        Margin="10, 0, 0, 0"
                        Spacing="2">
                <ToggleButton Content="Month"
                              IsChecked="{Binding IsMonthView}"
                              Command="{Binding SetViewModeCommand}"
                              CommandParameter="{x:Static cal:CalendarViewMode.Month}"
                              Padding="8, 4"
                              FontSize="12"/>
                <ToggleButton Content="Week"
                              IsChecked="{Binding IsWeekView}"
                              Command="{Binding SetViewModeCommand}"
                              CommandParameter="{x:Static cal:CalendarViewMode.Week}"
                              Padding="8, 4"
                              FontSize="12"/>
                <ToggleButton Content="5 Days"
                              IsChecked="{Binding IsFiveDaysView}"
                              Command="{Binding SetViewModeCommand}"
                              CommandParameter="{x:Static cal:CalendarViewMode.FiveDays}"
                              Padding="8, 4"
                              FontSize="12"/>
                <ToggleButton Content="Day"
                              IsChecked="{Binding IsDayView}"
                              Command="{Binding SetViewModeCommand}"
                              CommandParameter="{x:Static cal:CalendarViewMode.Day}"
                              Padding="8, 4"
                              FontSize="12"/>
                <ToggleButton Content="List"
                              IsChecked="{Binding IsListView}"
                              Command="{Binding SetViewModeCommand}"
                              CommandParameter="{x:Static cal:CalendarViewMode.List}"
                              Padding="8, 4"
                              FontSize="12"/>
            </StackPanel>
            
            <!-- Navigation Controls (Center) -->
            <StackPanel Grid.Column="1"
                        Orientation="Horizontal"
                        HorizontalAlignment="Center">
                <Button Command="{Binding PreviousCommand}"
                        Margin="0, 0, 8, 0"
                        Padding="8, 4">
                    ←
                </Button>
                <TextBlock Text="{Binding DateRangeDisplay}"
                           FontSize="16"
                           FontWeight="SemiBold"
                           VerticalAlignment="Center"
                           MinWidth="200"
                           TextAlignment="Center"
                           Margin="0, 0, 8, 0"/>
                <Button Command="{Binding TodayCommand}"
                        Margin="0, 0, 8, 0"
                        Padding="8, 4">
                    Today
                </Button>
                <Button Command="{Binding NextCommand}"
                        Padding="8, 4">
                    →
                </Button>
            </StackPanel>
            
            <!-- Spacer (Right) -->
            <Border Grid.Column="2"/>
        </Grid>

        <TextBlock Grid.Row="1" Grid.Column="0"
                   FontSize="{DynamicResource CalendarTimeHourFontSize}"
                   Foreground="Gray"
                   VerticalAlignment="Center"
                   Text="All-day"
                   Margin="4, 0, 4, 0"/>
        <StackPanel Grid.Column="1" Grid.Row="1">
            <!-- Weekday headers -->
            <!--<Grid Name="WeekdayNames" />-->
            <ItemsControl ItemsSource="{Binding WeekDayHeaders}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <UniformGrid Columns="{Binding WeekDayHeaders.Count}"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0, 0, 0, 8">
                            <TextBlock 
                                Text="{Binding EffectiveDate.Day}"
                                Margin="0, 0, 4, 0"
                                FontWeight="Bold"/>
                            <TextBlock Text="{Binding EffectiveDate.DayOfWeek}"/>
                        </StackPanel>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
            <ScrollViewer Name="TopView"
                          MinHeight="0"
                          VerticalScrollBarVisibility="Auto">
            </ScrollViewer>
            <Border Height="10" CornerRadius="0, 0, 10, 10">
                <Border.Background>
                    <LinearGradientBrush StartPoint="50%,0%" EndPoint="50%,100%">
                        <GradientStop Color="White" Offset="0" />
                        <GradientStop Color="DarkGray" Offset="0.2" />
                        <GradientStop Color="White" Offset="1" />
                    </LinearGradientBrush>
                </Border.Background>
            </Border>
        </StackPanel>
        <ScrollViewer Name="TimeRows" Grid.Column="0" Grid.Row="2"
                      VerticalScrollBarVisibility="Hidden"
                      Margin="5, 0, 5, 0">
        </ScrollViewer>
        <ScrollViewer Name="CenterView" Grid.Column="1" Grid.Row="2" Offset="{Binding #TimeRows.Offset, Mode=TwoWay}"
                      Effect="">
        </ScrollViewer>
    </Grid>

</UserControl>