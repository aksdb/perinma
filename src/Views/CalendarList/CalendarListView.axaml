<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:callist="using:perinma.Views.CalendarList"
             x:DataType="callist:CalendarListViewModel"
             mc:Ignorable="d" d:DesignWidth="250" d:DesignHeight="600"
             x:Class="perinma.Views.CalendarList.CalendarListView">

    <DockPanel Margin="10">
        <!-- Calendar Navigation -->
        <StackPanel DockPanel.Dock="Top">
            <Viewbox MaxHeight="250" Stretch="Uniform" HorizontalAlignment="Center" Margin="0, 0, 0, 10">
                <Calendar SelectedDate="{Binding CalendarWeekViewModel.WeekStart}" />
            </Viewbox>

            <TextBlock Text="Calendars"
                       FontSize="18"
                       FontWeight="Bold"
                       Margin="0,0,0,15" />
        </StackPanel>

        <ScrollViewer HorizontalScrollBarVisibility="Disabled"
                      VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <!-- Account Groups with Calendars (collapsible, drag & drop reorderable) -->
                <ItemsControl ItemsSource="{Binding AccountGroups}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="callist:AccountGroupViewModel">
                            <Border Background="Transparent"
                                    DragDrop.AllowDrop="True"
                                    Margin="0,0,0,5">
                                <StackPanel>
                                    <!-- Account Header with drag handle -->
                                    <DockPanel Margin="0,0,0,4">
                                        <!-- Drag handle -->
                                        <Border DockPanel.Dock="Left"
                                                Width="16"
                                                Cursor="SizeAll"
                                                Background="Transparent"
                                                PointerPressed="AccountGroup_PointerPressed"
                                                PointerMoved="AccountGroup_PointerMoved"
                                                VerticalAlignment="Center"
                                                Margin="0,0,4,0">
                                            <TextBlock Text="&#x2630;"
                                                       FontSize="10"
                                                       Foreground="Gray"
                                                       VerticalAlignment="Center"
                                                       HorizontalAlignment="Center" />
                                        </Border>

                                        <!-- Expand/collapse toggle -->
                                        <ToggleButton DockPanel.Dock="Left"
                                                      IsChecked="{Binding IsExpanded}"
                                                      Width="16" Height="16"
                                                      Padding="0"
                                                      Background="Transparent"
                                                      BorderThickness="0"
                                                      VerticalAlignment="Center"
                                                      Margin="0,0,4,0">
                                            <Panel>
                                                <TextBlock Text="&#x25B6;"
                                                           FontSize="8"
                                                           IsVisible="{Binding !IsExpanded}"
                                                           VerticalAlignment="Center"
                                                           HorizontalAlignment="Center" />
                                                <TextBlock Text="&#x25BC;"
                                                           FontSize="8"
                                                           IsVisible="{Binding IsExpanded}"
                                                           VerticalAlignment="Center"
                                                           HorizontalAlignment="Center" />
                                            </Panel>
                                        </ToggleButton>

                                        <!-- Account name -->
                                        <TextBlock Text="{Binding AccountName}"
                                                   FontWeight="SemiBold"
                                                   Foreground="Gray"
                                                   FontSize="12"
                                                   VerticalAlignment="Center" />
                                    </DockPanel>

                                    <!-- Calendars in this account (collapsible) -->
                                    <ItemsControl ItemsSource="{Binding Calendars}"
                                                  IsVisible="{Binding IsExpanded}"
                                                  Margin="20,0,0,0">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate x:DataType="callist:CalendarViewModel">
                                                <Border Padding="5,4"
                                                        Margin="0,2"
                                                        Background="Transparent">
                                                    <Border.ContextMenu>
                                                        <ContextMenu>
                                                            <MenuItem Header="Manage Permissions..."
                                                                      Command="{Binding ManagePermissionsCommand}"
                                                                      IsVisible="{Binding IsCalDav}" />
                                                        </ContextMenu>
                                                    </Border.ContextMenu>
                                                    <DockPanel>
                                                        <!-- Color indicator + Name -->
                                                        <StackPanel Orientation="Horizontal"
                                                                    Spacing="8">
                                                            <!-- Color Box (clickable to toggle) -->
                                                            <Border Width="16"
                                                                    Height="16"
                                                                    CornerRadius="3"
                                                                    Background="{Binding Color}"
                                                                    VerticalAlignment="Center"
                                                                    Cursor="Hand"
                                                                    PointerPressed="ColorBox_PointerPressed">
                                                                <TextBlock Text="&#x2713;"
                                                                           FontSize="12"
                                                                           FontWeight="Bold"
                                                                           Foreground="{Binding CheckmarkColor}"
                                                                           HorizontalAlignment="Center"
                                                                           VerticalAlignment="Center"
                                                                           IsVisible="{Binding Enabled}" />
                                                                <Border.Styles>
                                                                    <Style Selector="Border:pointerover">
                                                                        <Setter Property="Opacity" Value="0.8" />
                                                                    </Style>
                                                                    <Style Selector="Border">
                                                                        <Style.Animations>
                                                                            <Animation Duration="0:0:0.2"
                                                                                    Easing="CubicEaseOut">
                                                                                <KeyFrame Cue="0%">
                                                                                    <Setter Property="Opacity"
                                                                                        Value="1" />
                                                                                </KeyFrame>
                                                                            </Animation>
                                                                        </Style.Animations>
                                                                    </Style>
                                                                </Border.Styles>
                                                            </Border>

                                                            <!-- Calendar Name -->
                                                            <TextBlock Text="{Binding Name}"
                                                                       VerticalAlignment="Center"
                                                                       TextTrimming="CharacterEllipsis" />
                                                        </StackPanel>
                                                    </DockPanel>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- Placeholder message when no calendars exist -->
                <TextBlock Text="No calendars available"
                           Foreground="Gray"
                           FontSize="12"
                           Margin="0,10"
                           IsVisible="{Binding !AccountGroups.Count}" />
            </StackPanel>
        </ScrollViewer>
    </DockPanel>

</UserControl>