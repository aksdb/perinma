<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="perinma.Views.CalendarWeekView">
    
    <DockPanel>
        <!-- Top full-day events bar aligned to the right of the time column -->
        <Grid DockPanel.Dock="Top">
            <Grid.ColumnDefinitions>
                <!-- Empty spacer that mirrors the width of the time rows on the left -->
                <ColumnDefinition Width="{Binding #TimeRows.Bounds.Width}"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <!--Border Grid.Column="0"/-->
            <ScrollViewer Name="TopView" Grid.Column="1" MinHeight="50" Background="Aqua">
            </ScrollViewer>
        </Grid>
        <ScrollViewer Name="TimeRows" DockPanel.Dock="Left"
                      VerticalScrollBarVisibility="Hidden"
                      Margin="5, 0, 5, 0">
        </ScrollViewer>
        <ScrollViewer Name="CenterView" Offset="{Binding #TimeRows.Offset, Mode=TwoWay}" Effect="">
        </ScrollViewer>
    </DockPanel>
    
</UserControl>
