<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:views="using:perinma.Views"
             xmlns:vm="using:perinma.ViewModels"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="perinma.Views.CalendarWeekView">

    <UserControl.Resources>
        <x:Double x:Key="CalendarTimeHourFontSize">12</x:Double>
        <x:Double x:Key="CalendarTimeMinuteFontSize">9</x:Double>
    </UserControl.Resources>
    
    <UserControl.Styles>
        <!-- Template for TimeLabel templated control -->
        <Style Selector="views|TimeLabel">
            <Setter Property="Template">
                <ControlTemplate>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock FontSize="{DynamicResource CalendarTimeHourFontSize}"
                                   Foreground="Gray"
                                   VerticalAlignment="Top"
                                   Text="{Binding Hour, RelativeSource={RelativeSource TemplatedParent}, StringFormat={}{0:00}}"/>
                        <TextBlock FontSize="{DynamicResource CalendarTimeMinuteFontSize}"
                                   Foreground="Gray"
                                   VerticalAlignment="Top"
                                   Margin="2,0,0,0"
                                   Text="{Binding Minute, RelativeSource={RelativeSource TemplatedParent}, StringFormat={}{0:00}}"/>
                    </StackPanel>
                </ControlTemplate>
            </Setter>
        </Style>

        <!-- Template for EventChip templated control -->
        <Style Selector="vm|EventItemViewModel">
            <Setter Property="Template">
                <ControlTemplate>
                    <Border CornerRadius="10"
                            Background="{Binding BackgroundBrush, RelativeSource={RelativeSource TemplatedParent}}"
                            Bounds="{Binding AvailableBounds, RelativeSource={RelativeSource TemplatedParent}, Mode=OneWayToSource}">
                        <StackPanel Orientation="Vertical" Spacing="1" Margin="5, 2, 5, 2">
                            <TextBlock Text="{Binding Title, RelativeSource={RelativeSource TemplatedParent}}"
                                       FontWeight="Bold"
                                       TextTrimming="CharacterEllipsis"
                                       FontSize="{DynamicResource CalendarTimeHourFontSize}"
                                       Foreground="{Binding ForegroundBrush, RelativeSource={RelativeSource TemplatedParent}}"/>

                            <!-- Inline variant: single line with emoji and range -->
                            <TextBlock IsVisible="{Binding ShowInlineTimes, RelativeSource={RelativeSource TemplatedParent}}"
                                       Text="{Binding InlineTimeText, RelativeSource={RelativeSource TemplatedParent}}"
                                       FontSize="{DynamicResource CalendarTimeMinuteFontSize}"
                                       Foreground="{Binding ForegroundBrush, RelativeSource={RelativeSource TemplatedParent}}"
                                       TextTrimming="None"/>

                            <!-- Stacked variant: start and end on separate lines -->
                            <StackPanel Orientation="Vertical"
                                        IsVisible="{Binding ShowStackedTimes, RelativeSource={RelativeSource TemplatedParent}}"
                                        Spacing="0">
                                <TextBlock Text="{Binding StartTimeText, RelativeSource={RelativeSource TemplatedParent}}"
                                           FontSize="{DynamicResource CalendarTimeMinuteFontSize}"
                                           Foreground="{Binding ForegroundBrush, RelativeSource={RelativeSource TemplatedParent}}"/>
                                <TextBlock Text="{Binding EndTimeText, RelativeSource={RelativeSource TemplatedParent}}"
                                           FontSize="{DynamicResource CalendarTimeMinuteFontSize}"
                                           Foreground="{Binding ForegroundBrush, RelativeSource={RelativeSource TemplatedParent}}"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </ControlTemplate>
            </Setter>
        </Style>
    </UserControl.Styles>
    
    <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,*">
        <TextBlock Grid.Row="0" Grid.Column="0"
                   FontSize="{DynamicResource CalendarTimeHourFontSize}"
                   Foreground="Gray"
                   VerticalAlignment="Center"
                   Text="All-day"/>
        <StackPanel Grid.Column="1" Grid.Row="0">
            <!-- Weekday headers -->
            <Grid Name="WeekdayNames"/>
            <ScrollViewer Name="TopView"
                          MinHeight="0"
                          VerticalScrollBarVisibility="Auto">
            </ScrollViewer>
            <Border Height="10" CornerRadius="0, 0, 10, 10">
                <Border.Background>
                    <LinearGradientBrush StartPoint="50%,0%" EndPoint="50%,100%">
                        <GradientStop Color="White" Offset="0"/>
                        <GradientStop Color="DarkGray" Offset="0.2"/>
                        <GradientStop Color="White" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
            </Border>
        </StackPanel>
        <ScrollViewer Name="TimeRows" Grid.Column="0" Grid.Row="1"
                      VerticalScrollBarVisibility="Hidden"
                      Margin="5, 0, 5, 0">
        </ScrollViewer>
        <ScrollViewer Name="CenterView" Grid.Column="1" Grid.Row="1" Offset="{Binding #TimeRows.Offset, Mode=TwoWay}"
                      Effect="">
        </ScrollViewer>
    </Grid>

</UserControl>
