<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="perinma.Views.CalendarWeekView">
    
    <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,*">
        <ScrollViewer Name="TopView" Grid.Column="1" Grid.Row="0" MinHeight="50">
        </ScrollViewer>
        <ScrollViewer Name="TimeRows" Grid.Column="0" Grid.Row="1"
                      VerticalScrollBarVisibility="Hidden"
                      Margin="5, 0, 5, 0">
        </ScrollViewer>
        <ScrollViewer Name="CenterView" Grid.Column="1" Grid.Row="1" Offset="{Binding #TimeRows.Offset, Mode=TwoWay}" Effect="">
        </ScrollViewer>
    </Grid>
    
</UserControl>
